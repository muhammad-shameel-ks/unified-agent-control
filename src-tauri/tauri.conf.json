{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unified-agent-control",
  "version": "0.1.5",
  "identifier": "com.mallubeast.unified-agent-control",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Unified Agent Control",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1", "librsvg2-0", "patchelf"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "libappindicator-gtk3", "librsvg2", "patchelf"]
      }
    }
  },
  "plugins": {
    "cli": {
      "description": "Unified Agent Control - manage AI coding agents",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "description": "Project directory to open (e.g. '.' for current directory)",
          "required": false
        }
      ],
      "subcommands": {
        "update": {
          "description": "Update to the latest release from GitHub"
        }
      }
    }
  }
}
